                    "mode": { "type": "string", "nullable": true },
                    "groupBy": { "type": "string" },
                    "records": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "period": { "type": "string" },
                          "passengers": { "type": "integer", "nullable": true },
                          "tons": { "type": "number", "nullable": true },
                          "vehicles": { "type": "integer", "nullable": true }
