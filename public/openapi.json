            "schema": { "type": "string", "enum": ["year", "quarter", "month", "province"] }
          },
          {
            "name": "from",
            "in": "query",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "to",
            "in": "query",
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
