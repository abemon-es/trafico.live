    "/trenes/posiciones": {
      "get": {
        "tags": ["Trenes"],
        "operationId": "getTrainPositions",
        "summary": "Posiciones GPS de trenes en tiempo real",
        "description": "Posiciones GPS de ~115 trenes de Larga Distancia activos. Incluye retraso estimado en minutos. Actualización cada 2 minutos.\n\n**Tier mínimo:** PRO",
        "parameters": [
          {
            "name": "brand",
            "in": "query",
            "description": "Filtrar por marca Renfe (e.g. `AVE`, `Alvia`)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "GeoJSON FeatureCollection con posiciones de trenes",
            "content": {
              "application/geo+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string", "enum": ["FeatureCollection"] },
                    "updated_at": { "type": "string", "format": "date-time" },
                    "features": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": { "type": "string", "enum": ["Feature"] },
                          "geometry": {
                            "type": "object",
                            "properties": {
                              "type": { "type": "string", "enum": ["Point"] },
                              "coordinates": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
                            }
                          },
                          "properties": {
                            "type": "object",
                            "properties": {
                              "train_id": { "type": "string" },
                              "brand": { "type": "string" },
                              "origin": { "type": "string" },
                              "destination": { "type": "string" },
                              "delay_minutes": { "type": "integer", "nullable": true }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/maritimo": {
      "get": {
