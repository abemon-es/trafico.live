    "/search": {
      "get": {
        "tags": ["Búsqueda"],
        "operationId": "search",
        "summary": "Búsqueda full-text multicolección",
        "description": "Búsqueda sobre 26 colecciones Typesense: gasolineras, carreteras, cámaras, municipios, ZBE, estaciones ferroviarias, aeropuertos, paradas de tránsito, radares, alertas meteorológicas…\n\n**Tier mínimo:** FREE",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Consulta de búsqueda",
            "schema": { "type": "string", "minLength": 2, "example": "A-6 Madrid" }
          },
          {
            "name": "collections",
            "in": "query",
            "description": "Colecciones a buscar (coma-separadas). Por defecto: todas.",
            "schema": { "type": "string", "example": "gas_stations,roads" }
          },
          {
            "name": "lat",
            "in": "query",
            "description": "Latitud para ordenar por proximidad",
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "lon",
            "in": "query",
            "description": "Longitud para ordenar por proximidad",
            "schema": { "type": "number", "format": "float" }
          },
          { "$ref": "#/components/parameters/LimitParam" }
        ],
        "responses": {
          "200": {
            "description": "Resultados de búsqueda agrupados por colección",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "query": { "type": "string" },
                    "total": { "type": "integer" },
                    "results": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "found": { "type": "integer" },
                          "hits": { "type": "array", "items": { "type": "object" } }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    }
  }
