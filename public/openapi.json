    "/trenes/alertas": {
      "get": {
        "tags": ["Trenes"],
        "operationId": "getRailwayAlerts",
        "summary": "Alertas de servicio Renfe",
        "description": "Alertas activas de servicio Renfe: cancelaciones, retrasos >5 min. Fuente GTFS-RT. Actualización cada 2 minutos.\n\n**Tier mínimo:** FREE",
        "parameters": [
          {
            "name": "network",
            "in": "query",
            "description": "Filtrar por red de Cercanías",
