# Database (required)
DATABASE_URL=postgresql://user:password@pgbouncer-host:6440/trafico?schema=public

# Direct postgres URL for Prisma migrations (bypasses pgbouncer to avoid advisory lock conflicts
# with transaction pooling). Must point to postgres directly, not pgbouncer.
MIGRATE_DATABASE_URL=postgresql://user:password@postgres-host:5432/trafico?schema=public

# Redis (optional — caching and rate limiting disabled without it)
REDIS_URL=redis://host:6379

# API Authentication (required — comma-separated valid keys)
API_KEYS=key1,key2

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Base URL (required for sitemaps, canonical URLs, OG tags)
NEXT_PUBLIC_BASE_URL=https://trafico.live

# AEMET API Key (required for weather alerts and maritime forecasts)
AEMET_API_KEY=your-aemet-api-key

# Collector task name (required for collector services only)
# Valid: v16, incident, panel, detector, intensity, weather, camera, radar,
#        charger, speedlimit, gas-station, maritime-fuel, insights, risk-zones,
#        zbe, imd, andorra, portugal-weather, portugal-fuel, historical-accidents,
#        portugal-accidents, maritime-forecast, sasemar
TASK=

# Timezone (set in Docker for collector services)
TZ=Europe/Madrid

# Sentry (optional — error tracking disabled without it)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Cloudflare Turnstile (optional — adds bot protection to /sobre/contacto form).
# Without these, form skips captcha and ships unprotected.
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
