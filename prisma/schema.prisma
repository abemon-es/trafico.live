// ============================================
// TRAFFIC COUNTING STATIONS (Estaciones de Aforo)
// ============================================

model TrafficStation {
  id           String       @id @default(cuid())
  stationCode  String // DGT station code (e.g., "M-301-5")
  province     String? // INE 2-digit code
  provinceName String?
  municipalityCode String? // INE 5-digit code
  roadNumber   String // "A-1", "N-340", "AP-7"
  roadType     RoadType?
  kmPoint      Decimal      @db.Decimal(7, 2)
  stationType  StationType? // PERMANENT, SEMI_PERMANENT, PRIMARY, SECONDARY, COVERAGE
  lanes        String? // Number of lanes description
  configuration String? // Station configuration
  population   String? // Nearest population
  latitude     Decimal      @db.Decimal(9, 6)
  longitude    Decimal      @db.Decimal(9, 6)
  year         Int // Year of data
  imd          Int? // IMD total at this station
  imdLigeros   Int? // Light vehicles IMD
  imdPesados   Int? // Heavy vehicles IMD
  percentPesados Decimal?   @db.Decimal(5, 2)
  daysRecorded Int? // Days of actual measurement

  flows TrafficFlow[]

  @@unique([stationCode, year])
  @@index([roadNumber])
  @@index([province])
  @@index([year])
  @@index([stationType])
  @@index([imd])
  @@index([municipalityCode])
  @@index([latitude, longitude])
}

enum StationType {
  PERMANENT // 24h every day (permanente)
  SEMI_PERMANENT // 84 days (semipermanente)
  PRIMARY // 42-49 days (primaria)
  SECONDARY // 12 days (secundaria)
  COVERAGE // 2 working days/year (cobertura)
}

// ============================================
// TRAFFIC FLOW DATA (IMD - Intensidad Media Diaria)
// ============================================

model TrafficFlow {
  id             String    @id @default(cuid())
  roadNumber     String // "A-1", "N-340", "AP-7"
  roadType       RoadType?
  kmStart        Decimal   @db.Decimal(7, 2)
  kmEnd          Decimal   @db.Decimal(7, 2)
  province       String? // INE 2-digit code
  provinceName   String?
  year           Int
  imd            Int // Intensidad Media Diaria (vehicles/day)
  imdLigeros     Int? // Light vehicles IMD
  imdPesados     Int? // IMD of heavy vehicles (trucks, buses)
  percentPesados Decimal?  @db.Decimal(5, 2) // Percentage of heavy vehicles
  vhKmTotal      Decimal?  @db.Decimal(12, 2) // Vehicle-km total (millions)
  vhKmLigeros    Decimal?  @db.Decimal(12, 2) // Vehicle-km light vehicles
  vhKmPesados    Decimal?  @db.Decimal(12, 2) // Vehicle-km heavy vehicles
  segmentLength  Decimal?  @db.Decimal(7, 2) // Segment length in km
  sourceId       Int? // Original ArcGIS OBJECTID

  // Relation to counting station (optional, not all segments have a station)
  stationId String?
  station   TrafficStation? @relation(fields: [stationId], references: [id])

  @@unique([roadNumber, kmStart, kmEnd, year])
  @@index([roadNumber])
  @@index([province])
  @@index([year])
  @@index([roadType])
  @@index([stationId])
  @@index([imd])
}

// ============================================
// GAS STATIONS (Gasolineras)
// ============================================

model GasStation {
  id   String @id // IDEESS from MINETUR API
  name String // Rótulo (brand name: REPSOL, CEPSA, etc.)

  // Location
  latitude  Decimal @db.Decimal(9, 6)
  longitude Decimal @db.Decimal(9, 6)
  address   String?
  postalCode String? @db.VarChar(5)
  locality  String?
  municipality String?
  municipalityCode String? // INE code for relation

  // Administrative
  province     String? // INE 2-digit code
  provinceName String?
  communityCode String? // INE 2-digit code

  // Road association (for road listings)
  nearestRoad String? // "A-1", "N-340"
  roadKm      Decimal? @db.Decimal(7, 2)

  // Fuel prices (EUR) - Main fuels
  priceGasoleoA       Decimal? @db.Decimal(5, 3) // Diesel standard
  priceGasoleoB       Decimal? @db.Decimal(5, 3) // Diesel agricultural
  priceGasoleoPremium Decimal? @db.Decimal(5, 3) // Diesel premium
  priceGasolina95E5   Decimal? @db.Decimal(5, 3) // Gasolina 95 (E5)
  priceGasolina95E10  Decimal? @db.Decimal(5, 3) // Gasolina 95 (E10)
  priceGasolina98E5   Decimal? @db.Decimal(5, 3) // Gasolina 98 (E5)
  priceGasolina98E10  Decimal? @db.Decimal(5, 3) // Gasolina 98 (E10)

  // Alternative fuels
  priceGLP       Decimal? @db.Decimal(5, 3) // LPG
  priceGNC       Decimal? @db.Decimal(5, 3) // Compressed Natural Gas
  priceGNL       Decimal? @db.Decimal(5, 3) // Liquefied Natural Gas
  priceHidrogeno Decimal? @db.Decimal(5, 3) // Hydrogen
  priceAdblue    Decimal? @db.Decimal(5, 3) // AdBlue (DEF)

  // Biofuels
  priceGasoleoNuevoA Decimal? @db.Decimal(5, 3) // New diesel A (higher biofuel content)
  priceBioetanol     Decimal? @db.Decimal(5, 3) // Bioethanol
  priceBiodiesel     Decimal? @db.Decimal(5, 3) // Biodiesel

  // Station info
  schedule    String? // "L-D: 24H" or "L-S: 08:00-22:00"
  is24h       Boolean @default(false)
  margin      String? // D (right), I (left), N (not applicable)
  saleType    String? // P (public), R (restricted)

  // Timestamps
  lastPriceUpdate DateTime @db.Timestamptz
  lastUpdated     DateTime @default(now()) @db.Timestamptz

  // Relations
  priceHistory  GasStationPriceHistory[]

  @@index([province])
  @@index([municipality])
  @@index([nearestRoad])
  @@index([priceGasoleoA])
  @@index([priceGasolina95E5])
  @@index([is24h])
  @@index([communityCode])
  @@index([lastPriceUpdate])
  @@index([latitude, longitude])
}

model MaritimeStation {
  id   String @id // IDEESS from MINETUR API (maritime)
  name String // Brand name

  // Location
  latitude  Decimal @db.Decimal(9, 6)
  longitude Decimal @db.Decimal(9, 6)
  port      String? // Port name
  locality  String?

  // Administrative
  province     String?
  provinceName String?

  // Fuel prices (EUR) - Maritime fuels
  // Note: priceGasoleoB is normalized to per-litre (API returns bulk per 1000L)
  priceGasoleoA     Decimal? @db.Decimal(5, 3)
  priceGasoleoB     Decimal? @db.Decimal(5, 3)
  priceGasolina95E5 Decimal? @db.Decimal(5, 3)
  priceGasolina98E5 Decimal? @db.Decimal(5, 3)

  // Station info
  schedule String?
  is24h    Boolean @default(false)

  // Timestamps
  lastPriceUpdate DateTime @db.Timestamptz
  lastUpdated     DateTime @default(now()) @db.Timestamptz

  // Relations
  priceHistory MaritimePriceHistory[]

  @@index([province])
  @@index([port])
}

// Price history for trend analysis
model GasStationPriceHistory {
  id         String     @id @default(cuid())
  stationId  String
  station    GasStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  recordedAt DateTime   @db.Date // One record per day

  priceGasoleoA        Decimal? @db.Decimal(5, 3)
  priceGasoleoB        Decimal? @db.Decimal(5, 3)
  priceGasoleoPremium  Decimal? @db.Decimal(5, 3)
  priceGasolina95E5    Decimal? @db.Decimal(5, 3)
  priceGasolina95E10   Decimal? @db.Decimal(5, 3)
  priceGasolina98E5    Decimal? @db.Decimal(5, 3)
  priceGasolina98E10   Decimal? @db.Decimal(5, 3)
  priceGLP             Decimal? @db.Decimal(5, 3)
  priceGNC             Decimal? @db.Decimal(5, 3)
  priceGNL             Decimal? @db.Decimal(5, 3)
  priceHidrogeno       Decimal? @db.Decimal(5, 3)
  priceGasoleoNuevoA   Decimal? @db.Decimal(5, 3)
  priceBioetanol       Decimal? @db.Decimal(5, 3)
  priceBiodiesel       Decimal? @db.Decimal(5, 3)

  @@unique([stationId, recordedAt])
  @@index([stationId])
  @@index([recordedAt])
}

model MaritimePriceHistory {
  id         String          @id @default(cuid())
  stationId  String
  station    MaritimeStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  recordedAt DateTime        @db.Date

  priceGasoleoA     Decimal? @db.Decimal(5, 3)
  priceGasoleoB     Decimal? @db.Decimal(5, 3)
  priceGasolina95E5 Decimal? @db.Decimal(5, 3)
  priceGasolina98E5 Decimal? @db.Decimal(5, 3)

  @@unique([stationId, recordedAt])
  @@index([stationId])
  @@index([recordedAt])
}

// ============================================
// MARITIME WEATHER FORECASTS (AEMET)
// ============================================

enum MaritimeZoneType {
  COASTAL   // Costa (8 zones: Galicia, Cantábrico, Catalano-balear, etc.)
  HIGH_SEAS // Alta mar (6 areas: Atlántico norte/sur, Mediterráneo norte/sur, etc.)
}

model MaritimeWeatherForecast {
  id       String          @id @default(cuid())
  zoneId   String          // AEMET zone/area numeric ID as string
  zoneName String          // Human-readable name (e.g. "Galicia", "Cantábrico occidental")
  zoneType MaritimeZoneType

  issuedAt   DateTime       @db.Timestamptz // When AEMET issued this forecast
  validFrom  DateTime?      @db.Timestamptz
  validUntil DateTime?      @db.Timestamptz
  fetchedAt  DateTime       @db.Timestamptz

  // Extracted metrics (nullable — not always parseable from prose)
  waveHeightMin Decimal? @db.Decimal(4, 1) // metres
  waveHeightMax Decimal? @db.Decimal(4, 1) // metres
  windForceMin  Int?                        // Beaufort scale
  windForceMax  Int?                        // Beaufort scale
  windSpeedKmh  Int?                        // km/h (when given as speed)
  seaState      String?                     // "marejadilla", "marejada", "fuerte marejada", etc.
  visibility    String?                     // "buena", "regular", "mala"

  // Full forecast text stored as JSON { "text": "...", "periods": [...] }
  forecast Json

  @@unique([zoneId, issuedAt])
  @@index([zoneId])
  @@index([zoneType])
  @@index([issuedAt])
  @@index([fetchedAt])
}

// Daily aggregated statistics for fast queries
model FuelPriceDailyStats {
  id    String   @id @default(cuid())
  date  DateTime @db.Date
  scope String // "national", "province:28", "community:13", "road:A-1"

  // Gasóleo A
  avgGasoleoA Decimal? @db.Decimal(5, 3)
  minGasoleoA Decimal? @db.Decimal(5, 3)
  maxGasoleoA Decimal? @db.Decimal(5, 3)

  // Gasolina 95
  avgGasolina95 Decimal? @db.Decimal(5, 3)
  minGasolina95 Decimal? @db.Decimal(5, 3)
  maxGasolina95 Decimal? @db.Decimal(5, 3)

  // Gasolina 98
  avgGasolina98 Decimal? @db.Decimal(5, 3)
  minGasolina98 Decimal? @db.Decimal(5, 3)
  maxGasolina98 Decimal? @db.Decimal(5, 3)

  stationCount Int

  @@unique([date, scope])
  @@index([date])
  @@index([scope])
}

// Price alert subscriptions for fuel price notifications
model PriceAlert {
  id            String   @id @default(cuid())
  email         String
  fuelType      String   // "gasoleoA" or "gasolina95"
  targetPrice   Decimal  @db.Decimal(5,3)  // e.g. 1.300
  province      String?  // optional province filter (INE code)
  provinceName  String?
  isActive      Boolean  @default(true)
  lastNotified  DateTime?
  createdAt     DateTime @default(now())
  unsubscribeToken String @unique @default(cuid())

  @@index([email])
  @@index([isActive, fuelType])
}

// Weekly digest email subscribers
model DigestSubscriber {
  id               String   @id @default(cuid())
  email            String
  province         String?  // optional: personalize by province (INE code)
  provinceName     String?
  isActive         Boolean  @default(true)
  confirmedAt      DateTime? // null until email confirmed (double opt-in)
  lastSentAt       DateTime?
  unsubscribeToken String   @unique @default(cuid())
  createdAt        DateTime @default(now())

  @@unique([email])
  @@index([isActive, confirmedAt])
}

// StationDailyRanking model removed — rankings are computed live via SQL

// ---------------------------------------------------------------------------
// Noticias — unified content: auto-generated reports + manual articles
// ---------------------------------------------------------------------------

enum ArticleCategory {
  // Auto-generated — recurring
  DAILY_REPORT
  WEEKLY_REPORT
  PRICE_ALERT
  INCIDENT_DIGEST
  WEATHER_ALERT
  FUEL_TREND
  MONTHLY_REPORT
  // Auto-generated — analytical (evergreen)
  ANNUAL_REPORT
  ROAD_ANALYSIS
  // Manual
  GUIDE
  NEWS
  ANALYSIS
  REGULATORY
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  summary         String          @db.Text
  body            String          @db.Text
  category        ArticleCategory
  status          ArticleStatus   @default(PUBLISHED)

  source          String?
  sourceUrl       String?
  province        String?
  imageUrl        String?
  readTime        String?
  isAutoGenerated Boolean         @default(false)
  featured        Boolean         @default(false)
  editorialWeight Int             @default(5) // Feed ranking: 1-10 (monthly=10, weekly=7, daily=5, provincial=2)

  tags            ArticleTag[]

  publishedAt     DateTime        @default(now()) @db.Timestamptz
  createdAt       DateTime        @default(now()) @db.Timestamptz
  updatedAt       DateTime        @updatedAt

  @@index([category])
  @@index([status, publishedAt])
  @@index([province])
  @@index([featured, publishedAt])
  @@index([editorialWeight, publishedAt])
}

model Tag {
  id       String       @id @default(cuid())
  slug     String       @unique
  name     String
  articles ArticleTag[]

  @@index([slug])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}

// ============================================
// MARITIME EMERGENCIES — SASEMAR Historical
// ============================================
//
// Source: SASEMAR Open Data Hub (opendata-sasemar.hub.arcgis.com)
// Populated by: services/collector/tasks/sasemar/collector.ts (one-shot / manual)
// Coverage: 2019–2024 (years published by SASEMAR)

enum MaritimeEmergencyType {
  RESCUE      // Salvamento / búsqueda y rescate
  POLLUTION   // Contaminación marina
  MEDICAL     // Evacuación médica / asistencia sanitaria
  ASSISTANCE  // Auxilio / remolque / asistencia técnica
  OTHER       // Otros servicios
}

model MaritimeEmergency {
  id       String @id @default(cuid())
  sourceId String @unique // External ID from SASEMAR ArcGIS (OBJECTID or constructed key)

  // Temporal
  year        Int
  occurredAt  DateTime? @db.Timestamptz // Full datetime when available
  reportedAt  DateTime? @db.Timestamptz // When SASEMAR received the call

  // Classification
  type        MaritimeEmergencyType @default(OTHER)
  subtype     String? // Raw category string from source (e.g. "Persona caída al mar")
  severity    String? // "grave", "leve", "sin víctimas", etc.

  // Location
  latitude    Decimal?  @db.Decimal(9, 6)
  longitude   Decimal?  @db.Decimal(9, 6)
  zone        String?   // SASEMAR maritime zone (e.g. "Estrecho", "Atlántico Norte")
  description String?   @db.Text

  // Nearest coastal province (inferred from lat/lng bounding box)
  province     String? // INE 2-digit code
  provinceName String?

  // Vessel / rescue data (where available)
  vesselType  String? // "velero", "motoembarcación", "buque mercante", etc.
  personsInvolved Int?
  personsSaved    Int?
  personsMissing  Int?
  personsDeceased Int?

  // Ingestion metadata
  importedAt  DateTime @default(now()) @db.Timestamptz
  dataSource  String   @default("sasemar-arcgis") // "sasemar-arcgis" or "sasemar-local-file"

  @@index([year])
  @@index([type])
  @@index([province])
  @@index([occurredAt])
  @@index([zone])
  @@index([latitude, longitude])
}

// ============================================
// SPANISH PORTS (derived from MaritimeStation data)
// ============================================

enum PortType {
  commercial // Major commercial / cargo ports
  fishing    // Fishing ports and fish markets (lonjas)
  sports     // Sports and recreational marinas
  mixed      // Multi-use ports
}

model SpanishPort {
  id           String   @id @default(cuid())
  slug         String   @unique // URL-friendly identifier
  name         String   // Canonical port name (from MaritimeStation.port)
  type         PortType @default(mixed)

  // Location (centroid of station coordinates)
  latitude  Decimal  @db.Decimal(9, 6)
  longitude Decimal  @db.Decimal(9, 6)

  // Administrative
  province     String? // INE province code (2 digits)
  provinceName String?
  coastalZone  String? // AEMET coastal zone (e.g. "Galicia", "Cantábrico", "Mediterráneo")

  // Derived stats (updated by seed-ports.ts)
  stationCount Int @default(0) // Number of fuel stations in this port

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([province])
  @@index([type])
  @@index([coastalZone])
}

// ============================================
// LOCATION STATS (Cached aggregates per geo scope)
// ============================================

model LocationStats {
  id                    String   @id @default(cuid())

  // Geographic scope
  scopeType             String   // "community", "province", "municipality"
  scopeCode             String   // INE code
  scopeName             String   // Human-readable name

  // Static infrastructure counts
  cameraCount           Int      @default(0)
  radarCount            Int      @default(0)
  gasStationCount       Int      @default(0)
  evChargerCount        Int      @default(0)
  speedLimitCount       Int      @default(0)
  trafficStationCount   Int      @default(0)
  trafficFlowCount      Int      @default(0)
  roadCount             Int      @default(0)
  riskZoneCount         Int      @default(0)
  panelCount            Int      @default(0)
  zbeCount              Int      @default(0)
  articleCount          Int      @default(0)

  // Real-time counts
  activeIncidentCount   Int      @default(0)
  activeV16Count        Int      @default(0)
  activeWeatherAlerts   Int      @default(0)

  // Fuel price aggregates
  avgDieselPrice        Decimal? @db.Decimal(5, 3)
  avgGasoline95Price    Decimal? @db.Decimal(5, 3)
  minDieselPrice        Decimal? @db.Decimal(5, 3)
  minGasoline95Price    Decimal? @db.Decimal(5, 3)

  // Historical accidents (latest year)
  accidentsLatestYear   Int?
  fatalitiesLatestYear  Int?
  accidentYear          Int?

  // IMD summary
  avgIMD                Int?
  maxIMD                Int?

  // Freshness tracking
  staticUpdatedAt       DateTime  @default(now()) @db.Timestamptz
  realtimeUpdatedAt     DateTime  @default(now()) @db.Timestamptz
  pricesUpdatedAt       DateTime? @db.Timestamptz

  createdAt             DateTime  @default(now()) @db.Timestamptz
  updatedAt             DateTime  @updatedAt @db.Timestamptz

  @@unique([scopeType, scopeCode])
  @@index([scopeType])
  @@index([scopeCode])
}

// ============================================
// URL REDIRECTS (SEO)
// ============================================

model Redirect {
  id          String   @id @default(cuid())
  source      String   @unique // URL path, e.g. "/old-page"
  destination String   // Target path or full URL
  permanent   Boolean  @default(true) // true = 301, false = 302
  hits        Int      @default(0) // Track usage for cleanup
  lastHitAt   DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz
  note        String?  // Why this redirect exists

  @@index([source])
}

// ============================================
// RAILWAY NETWORK (Renfe + ADIF)
// ============================================

enum RailwayServiceType {
  CERCANIAS
  AVE
  AVLO
  ALVIA
  AVANT
  EUROMED
  LARGA_DISTANCIA
  MEDIA_DISTANCIA
  REGIONAL
  REGIONAL_EXPRESS
  PROXIMIDAD
  INTERCITY
  TRENHOTEL
  TRENCELTA
  FEVE
  RODALIES
}

enum RailwayAlertEffect {
  NO_SERVICE
  REDUCED_SERVICE
  SIGNIFICANT_DELAYS
  DETOUR
  ADDITIONAL_SERVICE
  MODIFIED_SERVICE
  STOP_MOVED
  OTHER_EFFECT
  UNKNOWN_EFFECT
}

model RailwayStation {
  id           String  @id @default(cuid())
  stopId       String  @unique // GTFS stop_id
  code         String? // Renfe station code (e.g. "60000" for Atocha)
  name         String
  slug         String? @unique // URL-safe name (e.g. "madrid-atocha")
  latitude     Decimal @db.Decimal(9, 6)
  longitude    Decimal @db.Decimal(9, 6)

  // Classification
  parentId     String? // GTFS parent_station (for grouped stops)
  locationType Int     @default(0) // GTFS location_type: 0=stop, 1=station
  platformCode String? // Platform number/code

  // Administrative (reverse-geocoded)
  province     String? // INE 2-digit
  provinceName String?
  community    String? // INE 2-digit community
  communityName String?
  municipality String?

  // Network (for Cercanías: Madrid, Barcelona, etc.)
  network      String?

  // Service info
  serviceTypes RailwayServiceType[] // Which services stop here
  wheelchair   Int?    @default(0) // GTFS wheelchair_boarding: 0=unknown, 1=yes, 2=no

  // Metadata
  source       String  @default("RENFE_GTFS")
  fetchedAt    DateTime @default(now()) @db.Timestamptz

  @@index([name])
  @@index([slug])
  @@index([province])
  @@index([network])
  @@index([serviceTypes])
  @@index([latitude, longitude])
  @@index([parentId])
}

model RailwayRoute {
  id          String  @id @default(cuid())
  routeId     String  @unique // GTFS route_id
  slug        String? // URL-safe (e.g. "ave-madrid-malaga")
  agencyId    String? // GTFS agency_id
  shortName   String? // Line name: "C1", "C3", "R1"
  longName    String? // GTFS long name
  brand       String? // Commercial brand: "AVE", "AVLO", "Alvia", "Avant", "Euromed", "MD", "Regional", etc.
  serviceType RailwayServiceType
  color       String? // Route color hex (GTFS route_color)
  textColor   String? // Text color hex (GTFS route_text_color)

  // Route endpoints (resolved from stop_times)
  originName  String? // e.g. "Madrid Pta.Atocha"
  originCode  String? // GTFS stop_id of origin
  destName    String? // e.g. "Málaga María Zambrano"
  destCode    String? // GTFS stop_id of destination

  // Network (for Cercanías grouping)
  network     String? // e.g. "Madrid", "Barcelona", "Valencia"

  // Route details
  stopsCount  Int?    // Number of intermediate stops
  tripCount   Int?    // Number of daily trips (services)

  // Shape geometry (from shapes.txt)
  shapeId     String?
  shapeGeoJSON Json?   // GeoJSON LineString or MultiLineString

  // Stop sequence
  stopIds     String[] // Ordered GTFS stop_ids for this route
  stopNames   String[] // Ordered stop names for display

  // Metadata
  source      String   @default("RENFE_GTFS")
  fetchedAt   DateTime @default(now()) @db.Timestamptz

  @@index([serviceType])
  @@index([brand])
  @@index([network])
  @@index([shortName])
  @@index([slug])
  @@index([originName])
  @@index([destName])
}

model RailwayAlert {
  id         String  @id @default(cuid())
  alertId    String  @unique // GTFS-RT alert id (e.g. "AVISO_484283")

  // Affected entities
  routeIds   String[] // GTFS route_ids affected
  stopIds    String[] // GTFS stop_ids affected
  tripIds    String[] // GTFS trip_ids affected

  // Alert content
  headerText   String?  @db.Text
  description  String   @db.Text // Alert description in Spanish
  url          String?  // External URL with more info
  cause        String?  // GTFS-RT cause enum as string
  effect       RailwayAlertEffect @default(UNKNOWN_EFFECT)

  // Temporal
  activePeriodStart DateTime  @db.Timestamptz
  activePeriodEnd   DateTime? @db.Timestamptz

  // Lifecycle
  isActive     Boolean  @default(true)
  firstSeenAt  DateTime @default(now()) @db.Timestamptz
  lastSeenAt   DateTime @default(now()) @db.Timestamptz
  fetchedAt    DateTime @default(now()) @db.Timestamptz

  // Source
  source       String   @default("RENFE_GTFS_RT")
  serviceType  RailwayServiceType?

  @@index([isActive])
  @@index([activePeriodStart])
  @@index([routeIds])
  @@index([source, isActive])
  @@index([serviceType])
}
