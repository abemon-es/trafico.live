// Prisma Schema for Spanish Road Intelligence Platform
// trafico.abemon.es

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// REAL-TIME EVENTS (Time-Series)
// ============================================

model V16BeaconEvent {
  id          String  @id @default(cuid())
  situationId String
  recordId    String?

  // Lifecycle tracking (for historical analysis)
  firstSeenAt  DateTime @default(now()) @db.Timestamptz // When we first observed this beacon
  lastSeenAt   DateTime @default(now()) @db.Timestamptz // Last time beacon appeared in API response
  durationSecs Int? // Calculated when deactivated (lastSeenAt - firstSeenAt)

  // DGT-provided timestamps
  activatedAt   DateTime  @db.Timestamptz
  deactivatedAt DateTime? @db.Timestamptz
  lastUpdatedAt DateTime  @db.Timestamptz
  fetchedAt     DateTime  @default(now()) @db.Timestamptz

  // Geographic data
  latitude  Decimal @db.Decimal(9, 6)
  longitude Decimal @db.Decimal(9, 6)

  // Location metadata
  roadNumber  String?
  roadType    RoadType?
  kmPoint     Decimal?   @db.Decimal(7, 2)
  direction   Direction?
  carriageway String?

  // Administrative division
  province      String? // INE code
  provinceName  String?
  community     String? // INE code
  communityName String?
  municipality  String? // Town name

  // Incident details
  severity     Severity     @default(LOW)
  mobilityType MobilityType @default(STATIONARY)
  description  String?      @db.Text

  // Status
  isActive Boolean @default(true)

  @@unique([situationId, recordId])
  @@index([activatedAt])
  @@index([province, activatedAt])
  @@index([community, activatedAt])
  @@index([isActive])
  @@index([roadNumber])
  @@index([lastSeenAt])
  @@index([isActive, lastSeenAt])
}

model TrafficIncident {
  id          String @id @default(cuid())
  situationId String @unique

  // Lifecycle tracking (for historical analysis)
  firstSeenAt  DateTime @default(now()) @db.Timestamptz // When we first observed this incident
  lastSeenAt   DateTime @default(now()) @db.Timestamptz // Last time incident appeared in API response
  durationSecs Int? // Calculated when deactivated (lastSeenAt - firstSeenAt)

  // Type and timing (from source)
  type      IncidentType
  startedAt DateTime     @db.Timestamptz
  endedAt   DateTime?    @db.Timestamptz
  fetchedAt DateTime     @default(now()) @db.Timestamptz

  // Geographic data
  latitude  Decimal @db.Decimal(9, 6)
  longitude Decimal @db.Decimal(9, 6)

  // Location metadata
  roadNumber String?
  roadType   RoadType?
  kmPoint    Decimal?   @db.Decimal(7, 2)
  direction  Direction?

  // Administrative division
  province      String?
  provinceName  String?
  community     String?
  communityName String?
  municipality  String? // Town name

  // Cause categorization (from DATEX II)
  causeType         String? // "roadMaintenance", "accident", "weather"
  detailedCauseType String? // "resurfacingWork", "fog", "ice", etc.
  managementType    String? // "laneClosures", "diversion", etc.

  // Details
  description String?  @db.Text
  severity    Severity
  source      String? // DGT, SCT, EUSKADI, MADRID, etc.

  // Status
  isActive Boolean @default(true)

  @@index([startedAt])
  @@index([type, isActive])
  @@index([province])
  @@index([roadNumber])
  @@index([source, isActive])
}

// ============================================
// TRAFFIC DETECTORS (Real-Time Flow Data)
// ============================================

model TrafficDetector {
  id         String  @id // DGT detector ID
  road       String
  kmPoint    Float?
  direction  String?
  latitude   Float
  longitude  Float
  province   String?
  lanes      Int?
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  readings   TrafficReading[]

  @@index([road])
  @@index([province])
  @@index([isActive])
}

model TrafficReading {
  id         String   @id @default(cuid())
  detectorId String
  detector   TrafficDetector @relation(fields: [detectorId], references: [id], onDelete: Cascade)
  intensity  Int      // vehicles/hour
  speed      Float?   // km/h average
  occupancy  Float?   // % lane occupancy
  measuredAt DateTime @db.Timestamptz
  fetchedAt  DateTime @default(now()) @db.Timestamptz

  @@index([detectorId, measuredAt])
  @@index([measuredAt])
}

// ============================================
// ROAD RISK ZONES (INVIVE, Motorcycle, Wildlife)
// ============================================

model RoadRiskZone {
  id            String       @id
  type          RiskZoneType
  road          String
  fromKm        Float
  toKm          Float
  startLat      Float
  startLng      Float
  endLat        Float?
  endLng        Float?
  province      String?
  description   String?
  severity      String?
  sourceUpdated DateTime?
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())

  @@index([type])
  @@index([road])
  @@index([province])
}

enum RiskZoneType {
  INVIVE       // Speed enforcement intensification
  MOTORCYCLE   // High motorcycle accident rate
  WILDLIFE     // Wildlife-vehicle collision hotspot
  CAMINO       // Camino de Santiago parallel/intersection risk
}

// ============================================
// ANDORRA
// ============================================

model AndorraIncident {
  id          String   @id @default(cuid())
  sourceId    Int      @unique // mobilitat.ad incident ID
  category    String   // BLAU, TARONJA, VERMELL, etc.
  categoryId  Int
  title       String
  description String?  @db.Text
  latitude    Float
  longitude   Float
  startedAt   DateTime @db.Timestamptz
  endedAt     DateTime? @db.Timestamptz
  isActive    Boolean  @default(true)
  fetchedAt   DateTime @default(now()) @db.Timestamptz

  @@index([isActive])
  @@index([startedAt])
}

model AndorraCamera {
  id        String  @id // camera slug from mobilitat.ad
  name      String
  latitude  Float
  longitude Float
  elevation Int?    // meters
  route     String? // CG1, CG2, etc.
  imageUrl  String
  isActive  Boolean @default(true)
  lastUpdated DateTime @default(now())

  @@index([route])
  @@index([isActive])
}

// ============================================
// PORTUGAL
// ============================================

model PortugalWeatherAlert {
  id          String   @id @default(cuid())
  alertId     String   @unique // IPMA warning ID
  type        String   // Agitação Marítima, Nevoeiro, Precipitação, etc.
  severity    String   // green, yellow, orange, red
  areaCode    String   // IPMA area code
  areaName    String?
  startedAt   DateTime @db.Timestamptz
  endedAt     DateTime? @db.Timestamptz
  description String?  @db.Text
  isActive    Boolean  @default(true)
  fetchedAt   DateTime @default(now()) @db.Timestamptz

  @@index([isActive])
  @@index([severity])
  @@index([areaCode])
}

model PortugalGasStation {
  id            String   @id // DGEG station ID
  name          String
  latitude      Float
  longitude     Float
  address       String?
  locality      String?
  postalCode    String?
  district      String?  // Portuguese district name
  districtId    String?  // District numeric ID
  municipality  String?
  municipalityId String?
  brand         String?

  // Fuel prices (EUR)
  priceGasoleoSimples   Decimal? @db.Decimal(5, 3)
  priceGasoleoEspecial  Decimal? @db.Decimal(5, 3)
  priceGasoleoColorido  Decimal? @db.Decimal(5, 3)
  priceGasolina95       Decimal? @db.Decimal(5, 3)
  priceGasolina95Especial Decimal? @db.Decimal(5, 3)
  priceGasolina98       Decimal? @db.Decimal(5, 3)
  priceGasolina98Especial Decimal? @db.Decimal(5, 3)
  priceGPL              Decimal? @db.Decimal(5, 3)
  priceGNC              Decimal? @db.Decimal(5, 3)

  // Station info
  stationType String? // road, urban
  is24h       Boolean @default(false)

  lastPriceUpdate DateTime? @db.Timestamptz
  lastUpdated     DateTime  @default(now()) @db.Timestamptz

  priceHistory PortugalGasStationPriceHistory[]

  @@index([district])
  @@index([municipality])
  @@index([priceGasoleoSimples])
  @@index([priceGasolina95])
}

model PortugalGasStationPriceHistory {
  id         String   @id @default(cuid())
  stationId  String
  station    PortugalGasStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  recordedAt DateTime @db.Date

  priceGasoleoSimples Decimal? @db.Decimal(5, 3)
  priceGasolina95     Decimal? @db.Decimal(5, 3)
  priceGasolina98     Decimal? @db.Decimal(5, 3)
  priceGPL            Decimal? @db.Decimal(5, 3)

  @@unique([stationId, recordedAt])
  @@index([stationId])
  @@index([recordedAt])
}

model PortugalHistoricalAccidents {
  id            String  @id @default(cuid())
  year          Int
  district      String  // Portuguese district
  districtName  String?
  accidents     Int
  fatalities    Int
  seriousInjury Int
  minorInjury   Int

  @@unique([year, district])
  @@index([year])
  @@index([district])
}

// AEMET weather alerts for traffic impact correlation
model WeatherAlert {
  id       String           @id @default(cuid())
  alertId  String           @unique
  type     WeatherAlertType
  severity Severity

  // Location
  province     String
  provinceName String?

  // Timing
  startedAt DateTime  @db.Timestamptz
  endedAt   DateTime? @db.Timestamptz
  fetchedAt DateTime  @default(now()) @db.Timestamptz

  // Details
  description String? @db.Text

  // Status
  isActive Boolean @default(true)

  @@index([province, isActive])
  @@index([type, isActive])
  @@index([startedAt])
}

enum WeatherAlertType {
  RAIN
  SNOW
  ICE
  FOG
  WIND
  TEMPERATURE
  STORM
  COASTAL
  OTHER
}

// ============================================
// INFRASTRUCTURE (Semi-Static)
// ============================================

model Camera {
  id   String @id
  name String

  // Location
  latitude   Decimal  @db.Decimal(9, 6)
  longitude  Decimal  @db.Decimal(9, 6)
  roadNumber String?
  kmPoint    Decimal? @db.Decimal(7, 2)

  // Administrative
  province     String?
  provinceName String?

  // Feed info
  feedUrl      String?
  thumbnailUrl String?

  // Status
  isActive    Boolean  @default(true)
  lastUpdated DateTime @default(now())

  @@index([province])
  @@index([roadNumber])
  @@index([isActive])
}

model VariablePanel {
  id      String  @id @default(cuid())
  panelId String  @unique // DGT panel identifier
  name    String? // Panel name/description

  // Location
  latitude   Decimal    @db.Decimal(9, 6)
  longitude  Decimal    @db.Decimal(9, 6)
  roadNumber String? // "A-1", "M-30"
  kmPoint    Decimal?   @db.Decimal(7, 2)
  direction  Direction?

  // Administrative
  province     String?
  provinceName String?

  // Current message
  message     String?           @db.Text // Current display text
  messageType PanelMessageType? // PRECAUTION, DANGER, INFO
  messageCode String? // DGT message code

  // Timing
  messageStartAt DateTime? @db.Timestamptz
  fetchedAt      DateTime  @default(now()) @db.Timestamptz
  lastUpdated    DateTime  @default(now()) @db.Timestamptz

  // Status
  isActive   Boolean @default(true)
  hasMessage Boolean @default(false) // Whether currently displaying message

  @@index([province])
  @@index([roadNumber])
  @@index([isActive])
  @@index([hasMessage, isActive])
}

enum PanelMessageType {
  PRECAUTION // Yellow warning
  DANGER // Red warning
  INFO // Information
  SPEED_LIMIT // Speed recommendation
  LANE_CLOSED // Lane closure
  DETOUR // Diversion
  OTHER
}

model EVCharger {
  id   String @id
  name String

  // Location
  latitude   Decimal @db.Decimal(9, 6)
  longitude  Decimal @db.Decimal(9, 6)
  address    String?
  city       String?
  postalCode String?

  // Administrative
  province     String?
  provinceName String?

  // Technical
  chargerTypes ChargerType[]
  powerKw      Decimal?      @db.Decimal(6, 2)
  connectors   Int?

  // Operator info
  operator String?
  network  String?

  // Availability
  isPublic Boolean @default(true)
  is24h    Boolean @default(false)

  // Payment
  paymentMethods String[]

  lastUpdated DateTime @default(now())

  @@index([province])
  @@index([city])
  @@index([isPublic])
}

model Radar {
  id      String @id @default(cuid())
  radarId String @unique // DGT radar identifier

  // Location
  latitude   Decimal    @db.Decimal(9, 6)
  longitude  Decimal    @db.Decimal(9, 6)
  roadNumber String // "A-1", "N-340"
  kmPoint    Decimal    @db.Decimal(7, 2)
  direction  Direction?

  // Administrative
  province     String?
  provinceName String?

  // Technical
  type            RadarType
  speedLimit      Int? // km/h
  avgSpeedPartner String? // For section radars, paired radar ID

  // Status
  isActive    Boolean  @default(true)
  lastUpdated DateTime @default(now()) @db.Timestamptz

  @@index([province])
  @@index([roadNumber])
  @@index([type])
  @@index([isActive])
}

enum RadarType {
  FIXED // Fixed speed camera
  SECTION // Average speed check (tramo)
  MOBILE_ZONE // Mobile radar zone
  TRAFFIC_LIGHT // Red light camera
}

model ZBEZone {
  id       String @id
  name     String
  cityName String

  // Geographic boundary (GeoJSON)
  polygon  Json
  centroid Json? // { lat, lng }

  // Restrictions by vehicle label
  restrictions Json // { "A": "denied", "B": "restricted", "C": "allowed", ... }

  // Schedule
  schedule      Json? // Operating hours
  activeAllYear Boolean @default(true)

  // Penalties
  fineAmount Decimal? @db.Decimal(8, 2)

  // Dates
  effectiveFrom  DateTime
  effectiveUntil DateTime?

  // Source
  sourceUrl   String?
  lastUpdated DateTime @default(now())

  @@index([cityName])
}

model RiskZone {
  id   String   @id
  type RiskType

  // Location
  roadNumber String
  kmStart    Decimal @db.Decimal(7, 2)
  kmEnd      Decimal @db.Decimal(7, 2)

  // Geographic (optional LineString)
  geometry Json?

  // Details
  severity    Severity
  description String?

  // For animal zones
  animalType    String? // deer, wild boar, etc.
  incidentCount Int? // historical count

  lastUpdated DateTime @default(now())

  @@index([type])
  @@index([roadNumber])
}

// ============================================
// STATISTICS (Aggregates)
// ============================================

model HourlyStats {
  id        String   @id @default(cuid())
  hourStart DateTime @unique @db.Timestamptz

  // Counts
  v16Count       Int @default(0)
  incidentCount  Int @default(0)
  newActivations Int @default(0)
  deactivations  Int @default(0)

  // Breakdowns (JSON for flexibility)
  byProvince     Json? // { "28": 45, "08": 32 }
  byCommunity    Json? // { "13": 120, "09": 85 }
  byRoadType     Json? // { "AUTOPISTA": 20, "NACIONAL": 45 }
  bySeverity     Json? // { "LOW": 50, "MEDIUM": 30, "HIGH": 10 }
  byIncidentType Json? // { "ACCIDENT": 5, "ROADWORK": 12 }

  // Weather
  weatherAlerts Int @default(0)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hourStart])
}

model DailyStats {
  id        String   @id @default(cuid())
  dateStart DateTime @unique @db.Date

  // Aggregated metrics
  v16Total      Int @default(0)
  incidentTotal Int @default(0)

  // Peak analysis
  peakHour  Int?
  peakCount Int?

  // Duration
  avgDurationSecs Int?

  // Breakdowns
  byHourOfDay    Json? // { "0": 12, "1": 8, ... "23": 45 }
  byProvince     Json?
  byCommunity    Json?
  byRoadType     Json?
  byIncidentType Json?

  // Weather summary
  weatherAlertDays Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dateStart])
}

model HistoricalAccidents {
  id           String  @id @default(cuid())
  year         Int
  province     String
  provinceName String?

  // Counts
  accidents       Int
  fatalities      Int
  hospitalized    Int
  nonHospitalized Int

  // Road type breakdown
  roadType RoadType?

  // Additional metrics
  vehiclesInvolved Int?
  pedestrians      Int?

  @@unique([year, province, roadType])
  @@index([year])
  @@index([province])
  @@index([province, year])
}

// VehicleFleet model removed — was never populated by any collector or seed

// ============================================
// REFERENCE DATA
// ============================================

model Province {
  code          String    @id // INE 2-digit code: "28", "08"
  name          String // "Madrid", "Barcelona"
  slug          String    @unique // URL-friendly: "madrid"
  communityCode String
  community     Community @relation(fields: [communityCode], references: [code])

  // Stats (cached)
  population Int?
  area       Decimal? @db.Decimal(10, 2) // km2

  // Municipalities
  municipalities Municipality[]

  @@index([communityCode])
  @@index([slug])
}

model Community {
  code String @id // INE 2-digit code: "13", "09"
  name String // "Comunidad de Madrid", "Cataluña"
  slug String @unique // URL-friendly: "comunidad-de-madrid"

  // Flag for regions with their own traffic systems
  isExcluded     Boolean @default(false)
  excludedReason String? // "Regional traffic system"

  provinces Province[]

  @@index([slug])
}

model Municipality {
  code         String   @id // INE 5-digit code: "28079" (Madrid city)
  name         String // "Madrid"
  slug         String   @unique // URL-friendly: "madrid"
  provinceCode String
  province     Province @relation(fields: [provinceCode], references: [code])

  // Stats
  population Int?
  area       Decimal? @db.Decimal(10, 2) // km2

  // Geographic center (optional)
  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  @@index([provinceCode])
  @@index([slug])
}

model Road {
  id   String   @id // "A-1", "AP-7", "N-340"
  name String? // "Autovía del Norte"
  type RoadType

  // Coverage
  kmStart Decimal? @db.Decimal(7, 2)
  kmEnd   Decimal? @db.Decimal(7, 2)
  totalKm Decimal? @db.Decimal(7, 2)

  // Provinces it passes through
  provinces String[]

  // Speed limits for this road
  speedLimits SpeedLimit[]

  @@index([type])
}

// Speed limits by road segment (ROSATTE format from NAP)
model SpeedLimit {
  id String @id @default(cuid())

  // Road reference
  roadNumber String // "A-1", "N-340", "AP-7"
  roadType   RoadType?
  road       Road?     @relation(fields: [roadNumber], references: [id])

  // Segment location
  kmStart Decimal @db.Decimal(7, 2)
  kmEnd   Decimal @db.Decimal(7, 2)

  // Geographic coordinates (segment endpoints)
  startLat Decimal? @db.Decimal(9, 6)
  startLng Decimal? @db.Decimal(9, 6)
  endLat   Decimal? @db.Decimal(9, 6)
  endLng   Decimal? @db.Decimal(9, 6)

  // Speed limit details
  speedLimit      Int // km/h (20, 30, 40, 50, 60, 70, 80, 90, 100, 110, 120)
  speedLimitType  SpeedLimitType @default(GENERAL)
  vehicleType     VehicleCategory? // Specific vehicle type restriction
  laneType        LaneType? // Specific lane restriction
  direction       Direction?

  // Conditions (when limit applies)
  isConditional Boolean @default(false)
  conditionType String? // "weather", "time", "congestion"
  timeStart     String? // "07:00" for time-based limits
  timeEnd       String? // "21:00"
  weatherType   String? // "rain", "fog", "snow"

  // Administrative
  province     String?
  provinceName String?

  // Source metadata
  sourceId    String? // ROSATTE segment ID
  lastUpdated DateTime @default(now()) @db.Timestamptz

  @@unique([roadNumber, kmStart, kmEnd, direction, vehicleType])
  @@index([roadNumber])
  @@index([speedLimit])
  @@index([province])
  @@index([speedLimitType])
  @@index([roadNumber, direction])
  @@index([province, speedLimitType])
}

// ============================================
// REAL-TIME TRAFFIC INTENSITY (Madrid sensors)
// ============================================

model TrafficIntensity {
  id            String   @id @default(cuid())
  sensorId      Int // Madrid PM sensor ID (idelem)
  description   String? // Location description
  intensity     Int // Vehicles/hour
  occupancy     Int? // Occupancy percentage
  load          Int? // Load percentage
  serviceLevel  Int // 0=fluid, 1=slow, 2=holdups, 3=congestion
  saturation    Int? // Saturation intensity (capacity)
  latitude      Decimal  @db.Decimal(9, 6)
  longitude     Decimal  @db.Decimal(9, 6)
  source        String   @default("MADRID") // City source
  recordedAt    DateTime @default(now()) @db.Timestamptz
  error         Boolean  @default(false)

  @@unique([sensorId, source, recordedAt])
  @@index([source])
  @@index([recordedAt])
  @@index([serviceLevel])
}

// Aggregated hourly traffic profile per sensor
model HourlyTrafficProfile {
  id         String @id @default(cuid())
  sensorId   Int
  source     String @default("MADRID")
  dayOfWeek  Int // 0=Sunday, 6=Saturday
  hour       Int // 0-23
  avgIntensity   Int
  avgOccupancy   Int?
  avgServiceLevel Decimal? @db.Decimal(3, 2) // 0.00-3.00
  sampleCount    Int // Number of observations
  updatedAt  DateTime @default(now()) @db.Timestamptz

  @@unique([sensorId, source, dayOfWeek, hour])
  @@index([source, dayOfWeek, hour])
}

enum SpeedLimitType {
  GENERAL // Standard speed limit
  URBAN // Urban area limit
  RESIDENTIAL // Residential zone (30 km/h)
  SCHOOL // School zone
  WORK_ZONE // Construction/roadwork
  WEATHER // Weather-dependent
  VARIABLE // Variable speed limit (PMV controlled)
  TUNNEL // Tunnel speed limit
  BRIDGE // Bridge speed limit
}

enum VehicleCategory {
  ALL // All vehicles
  CAR // Passenger cars
  MOTORCYCLE
  TRUCK // Heavy goods vehicles
  BUS // Buses and coaches
  TRAILER // Vehicles with trailers
  DANGEROUS_GOODS // ADR vehicles
}

enum LaneType {
  ALL // All lanes
  RIGHT // Right lane(s)
  LEFT // Left/fast lane
  MIDDLE // Middle lane(s)
  BUS_LANE // Bus lane
  HOV // High occupancy vehicle lane
}

// ============================================
// ENUMS
// ============================================

enum RoadType {
  AUTOPISTA // AP-* (toll motorway)
  AUTOVIA // A-* (motorway)
  NACIONAL // N-* (national road)
  COMARCAL // C-* (regional road)
  PROVINCIAL // Provincial roads
  URBANA // Urban roads
  OTHER
}

enum Direction {
  ASCENDING // Km increasing
  DESCENDING // Km decreasing
  BOTH
  UNKNOWN
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum MobilityType {
  MOBILE
  STATIONARY
  UNKNOWN
}

enum IncidentType {
  ACCIDENT
  ROADWORK
  CONGESTION
  HAZARD
  VEHICLE_BREAKDOWN
  WEATHER
  EVENT
  CLOSURE
  OTHER
}

// WeatherType and WeatherSeverity enums removed — WeatherCondition model was deprecated

enum ChargerType {
  AC_TYPE1
  AC_TYPE2
  DC_CHADEMO
  DC_CCS
  DC_CCS2
  TESLA
  SCHUKO
  OTHER
}

enum RiskType {
  MOTORCYCLE
  ANIMAL
  CYCLIST
  PEDESTRIAN
}

// ============================================
// TRAFFIC COUNTING STATIONS (Estaciones de Aforo)
// ============================================

model TrafficStation {
  id           String       @id @default(cuid())
  stationCode  String // DGT station code (e.g., "M-301-5")
  province     String? // INE 2-digit code
  provinceName String?
  roadNumber   String // "A-1", "N-340", "AP-7"
  roadType     RoadType?
  kmPoint      Decimal      @db.Decimal(7, 2)
  stationType  StationType? // PERMANENT, SEMI_PERMANENT, PRIMARY, SECONDARY, COVERAGE
  lanes        String? // Number of lanes description
  configuration String? // Station configuration
  population   String? // Nearest population
  latitude     Decimal      @db.Decimal(9, 6)
  longitude    Decimal      @db.Decimal(9, 6)
  year         Int // Year of data
  imd          Int? // IMD total at this station
  imdLigeros   Int? // Light vehicles IMD
  imdPesados   Int? // Heavy vehicles IMD
  percentPesados Decimal?   @db.Decimal(5, 2)
  daysRecorded Int? // Days of actual measurement

  flows TrafficFlow[]

  @@unique([stationCode, year])
  @@index([roadNumber])
  @@index([province])
  @@index([year])
  @@index([stationType])
}

enum StationType {
  PERMANENT // 24h every day (permanente)
  SEMI_PERMANENT // 84 days (semipermanente)
  PRIMARY // 42-49 days (primaria)
  SECONDARY // 12 days (secundaria)
  COVERAGE // 2 working days/year (cobertura)
}

// ============================================
// TRAFFIC FLOW DATA (IMD - Intensidad Media Diaria)
// ============================================

model TrafficFlow {
  id             String    @id @default(cuid())
  roadNumber     String // "A-1", "N-340", "AP-7"
  roadType       RoadType?
  kmStart        Decimal   @db.Decimal(7, 2)
  kmEnd          Decimal   @db.Decimal(7, 2)
  province       String? // INE 2-digit code
  provinceName   String?
  year           Int
  imd            Int // Intensidad Media Diaria (vehicles/day)
  imdLigeros     Int? // Light vehicles IMD
  imdPesados     Int? // IMD of heavy vehicles (trucks, buses)
  percentPesados Decimal?  @db.Decimal(5, 2) // Percentage of heavy vehicles
  vhKmTotal      Decimal?  @db.Decimal(12, 2) // Vehicle-km total (millions)
  vhKmLigeros    Decimal?  @db.Decimal(12, 2) // Vehicle-km light vehicles
  vhKmPesados    Decimal?  @db.Decimal(12, 2) // Vehicle-km heavy vehicles
  segmentLength  Decimal?  @db.Decimal(7, 2) // Segment length in km
  sourceId       Int? // Original ArcGIS OBJECTID

  // Relation to counting station (optional, not all segments have a station)
  stationId String?
  station   TrafficStation? @relation(fields: [stationId], references: [id])

  @@unique([roadNumber, kmStart, kmEnd, year])
  @@index([roadNumber])
  @@index([province])
  @@index([year])
  @@index([roadType])
  @@index([stationId])
}

// ============================================
// GAS STATIONS (Gasolineras)
// ============================================

model GasStation {
  id   String @id // IDEESS from MINETUR API
  name String // Rótulo (brand name: REPSOL, CEPSA, etc.)

  // Location
  latitude  Decimal @db.Decimal(9, 6)
  longitude Decimal @db.Decimal(9, 6)
  address   String?
  postalCode String? @db.VarChar(5)
  locality  String?
  municipality String?
  municipalityCode String? // INE code for relation

  // Administrative
  province     String? // INE 2-digit code
  provinceName String?
  communityCode String? // INE 2-digit code

  // Road association (for road listings)
  nearestRoad String? // "A-1", "N-340"
  roadKm      Decimal? @db.Decimal(7, 2)

  // Fuel prices (EUR) - Main fuels
  priceGasoleoA       Decimal? @db.Decimal(5, 3) // Diesel standard
  priceGasoleoB       Decimal? @db.Decimal(5, 3) // Diesel agricultural
  priceGasoleoPremium Decimal? @db.Decimal(5, 3) // Diesel premium
  priceGasolina95E5   Decimal? @db.Decimal(5, 3) // Gasolina 95 (E5)
  priceGasolina95E10  Decimal? @db.Decimal(5, 3) // Gasolina 95 (E10)
  priceGasolina98E5   Decimal? @db.Decimal(5, 3) // Gasolina 98 (E5)
  priceGasolina98E10  Decimal? @db.Decimal(5, 3) // Gasolina 98 (E10)

  // Alternative fuels
  priceGLP       Decimal? @db.Decimal(5, 3) // LPG
  priceGNC       Decimal? @db.Decimal(5, 3) // Compressed Natural Gas
  priceGNL       Decimal? @db.Decimal(5, 3) // Liquefied Natural Gas
  priceHidrogeno Decimal? @db.Decimal(5, 3) // Hydrogen
  priceAdblue    Decimal? @db.Decimal(5, 3) /// @deprecated MINETUR API does not provide AdBlue prices — always null

  // Station info
  schedule    String? // "L-D: 24H" or "L-S: 08:00-22:00"
  is24h       Boolean @default(false)
  margin      String? // D (right), I (left), N (not applicable)
  saleType    String? // P (public), R (restricted)

  // Timestamps
  lastPriceUpdate DateTime @db.Timestamptz
  lastUpdated     DateTime @default(now()) @db.Timestamptz

  // Relations
  priceHistory  GasStationPriceHistory[]

  @@index([province])
  @@index([municipality])
  @@index([nearestRoad])
  @@index([priceGasoleoA])
  @@index([priceGasolina95E5])
  @@index([is24h])
  @@index([communityCode])
  @@index([lastPriceUpdate])
}

model MaritimeStation {
  id   String @id // IDEESS from MINETUR API (maritime)
  name String // Brand name

  // Location
  latitude  Decimal @db.Decimal(9, 6)
  longitude Decimal @db.Decimal(9, 6)
  port      String? // Port name
  locality  String?

  // Administrative
  province     String?
  provinceName String?

  // Fuel prices (EUR) - Maritime fuels
  // Note: priceGasoleoB is normalized to per-litre (API returns bulk per 1000L)
  priceGasoleoA     Decimal? @db.Decimal(5, 3)
  priceGasoleoB     Decimal? @db.Decimal(5, 3)
  priceGasolina95E5 Decimal? @db.Decimal(5, 3)
  priceGasolina98E5 Decimal? @db.Decimal(5, 3)

  // Station info
  schedule String?
  is24h    Boolean @default(false)

  // Timestamps
  lastPriceUpdate DateTime @db.Timestamptz
  lastUpdated     DateTime @default(now()) @db.Timestamptz

  // Relations
  priceHistory MaritimePriceHistory[]

  @@index([province])
  @@index([port])
}

// Price history for trend analysis
model GasStationPriceHistory {
  id         String     @id @default(cuid())
  stationId  String
  station    GasStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  recordedAt DateTime   @db.Date // One record per day

  // Main prices only (to control table size)
  priceGasoleoA     Decimal? @db.Decimal(5, 3)
  priceGasolina95E5 Decimal? @db.Decimal(5, 3)
  priceGasolina98E5 Decimal? @db.Decimal(5, 3)
  priceGLP          Decimal? @db.Decimal(5, 3)

  @@unique([stationId, recordedAt])
  @@index([stationId])
  @@index([recordedAt])
}

model MaritimePriceHistory {
  id         String          @id @default(cuid())
  stationId  String
  station    MaritimeStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  recordedAt DateTime        @db.Date

  priceGasoleoA     Decimal? @db.Decimal(5, 3)
  priceGasolina95E5 Decimal? @db.Decimal(5, 3)

  @@unique([stationId, recordedAt])
  @@index([stationId])
  @@index([recordedAt])
}

// Daily aggregated statistics for fast queries
model FuelPriceDailyStats {
  id    String   @id @default(cuid())
  date  DateTime @db.Date
  scope String // "national", "province:28", "community:13", "road:A-1"

  // Gasóleo A
  avgGasoleoA Decimal? @db.Decimal(5, 3)
  minGasoleoA Decimal? @db.Decimal(5, 3)
  maxGasoleoA Decimal? @db.Decimal(5, 3)

  // Gasolina 95
  avgGasolina95 Decimal? @db.Decimal(5, 3)
  minGasolina95 Decimal? @db.Decimal(5, 3)
  maxGasolina95 Decimal? @db.Decimal(5, 3)

  // Gasolina 98
  avgGasolina98 Decimal? @db.Decimal(5, 3)
  minGasolina98 Decimal? @db.Decimal(5, 3)
  maxGasolina98 Decimal? @db.Decimal(5, 3)

  stationCount Int

  @@unique([date, scope])
  @@index([date])
  @@index([scope])
}

// Price alert subscriptions for fuel price notifications
model PriceAlert {
  id            String   @id @default(cuid())
  email         String
  fuelType      String   // "gasoleoA" or "gasolina95"
  targetPrice   Decimal  @db.Decimal(5,3)  // e.g. 1.300
  province      String?  // optional province filter (INE code)
  provinceName  String?
  isActive      Boolean  @default(true)
  lastNotified  DateTime?
  createdAt     DateTime @default(now())
  unsubscribeToken String @unique @default(cuid())

  @@index([email])
  @@index([isActive, fuelType])
}

// StationDailyRanking model removed — rankings are computed live via SQL

// ---------------------------------------------------------------------------
// Noticias — unified content: auto-generated reports + manual articles
// ---------------------------------------------------------------------------

enum ArticleCategory {
  // Auto-generated — recurring
  DAILY_REPORT
  WEEKLY_REPORT
  PRICE_ALERT
  INCIDENT_DIGEST
  WEATHER_ALERT
  FUEL_TREND
  MONTHLY_REPORT
  // Auto-generated — analytical (evergreen)
  ANNUAL_REPORT
  ROAD_ANALYSIS
  // Manual
  GUIDE
  NEWS
  ANALYSIS
  REGULATORY
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  summary         String          @db.Text
  body            String          @db.Text
  category        ArticleCategory
  status          ArticleStatus   @default(PUBLISHED)

  source          String?
  sourceUrl       String?
  province        String?
  imageUrl        String?
  readTime        String?
  isAutoGenerated Boolean         @default(false)
  featured        Boolean         @default(false)
  editorialWeight Int             @default(5) // Feed ranking: 1-10 (monthly=10, weekly=7, daily=5, provincial=2)

  tags            ArticleTag[]

  publishedAt     DateTime        @default(now()) @db.Timestamptz
  createdAt       DateTime        @default(now()) @db.Timestamptz
  updatedAt       DateTime        @updatedAt

  @@index([category])
  @@index([status, publishedAt])
  @@index([province])
  @@index([featured, publishedAt])
  @@index([editorialWeight, publishedAt])
}

model Tag {
  id       String       @id @default(cuid())
  slug     String       @unique
  name     String
  articles ArticleTag[]

  @@index([slug])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}
