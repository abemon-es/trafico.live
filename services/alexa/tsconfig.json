{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "../voice-shared/src/*": ["../voice-shared/src/*"]
    }
  },
  "include": ["src/**/*", "../voice-shared/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
