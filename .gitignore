# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# blitz sessions & claude
.blitz/
.claude/worktrees/
.playwright-mcp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
