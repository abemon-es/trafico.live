# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# WIP scripts
/scripts/

# Collector node_modules
services/v16-collector/node_modules/
services/incident-collector/node_modules/

# Brand/design assets in repo root (working files, not for version control)
*.png
*.svg
!public/**/*.svg
!public/**/*.png
snapshot-*.md
.wrangler/
