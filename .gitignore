# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# blitz sessions & claude
.blitz/
.claude/worktrees/
.playwright-mcp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# WIP scripts
/scripts/

# Municipality geocode cache (generated by enrich-municipalities.ts)
data/.municipality-geocode-cache.json

# Collector node_modules
services/v16-collector/node_modules/
services/incident-collector/node_modules/
services/collector/node_modules/

# Dev/preview artifacts
mcp-config.json
preview-map-styles.html

# Brand/design assets in repo root (working files, not for version control)
*.png
*.svg
!public/**/*.svg
!public/**/*.png
snapshot-*.md
.wrangler/

# MCP server (standalone, not part of Next.js build)
src/mcp/

# packages/mcp-server build artifacts and dependencies
packages/mcp-server/dist/
packages/mcp-server/node_modules/
